{
	"_version": "1.9.0",
	"sap.app": {
		"version": "1.9.0",
		"id": "com.nikitatrainings",
		"type": "application",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"title": "{{appTitle}}",
		"description": "{{appDesc}}",
		"tags": {
			"keywords": [
				"{{appTag1}}"
			]
		},
		"ach": "FIN-ACC-AP"
	},
	"sap.ui": {
		"version": "1.9.0",
		"technology": "UI5",
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		},
		"supportedThemes": [
			"sap_bluecrystal",
			"sap_belize"
		],
		"icons": {
			"icon": "sap-icon://accidental-leave"
		}
	},
	"sap.ui5": {
		"version": "1.9.0",
		"dependencies": {
			"minUI5Version": "1.56.10",
			"libs": {
				"sap.ui.layout": {
					"minVersion": ""
				},
				"sap.m": {
					"minVersion": ""
				}
			}
		},
		"rootView": {
			"viewName": "com.nikitatrainings.view.Login",
			"type": "XML"
		},
		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"viewType": "XML",
				"viewPath": "com.nikitatrainings.view",
				"controlId": "idMainApp"
			},
			"routes": [
				{
					"pattern": "split",
					"name": "App",
					"target": ["App"],
					"subroutes": [
						{
							"pattern": "master",
							"name": "master",
							"target": [
								"donald","trumph"
							]
						},
						{
							"name": "detail",
							"pattern": "fruitDetails/{navya}",
							"titleTarget": "",
							"greedy": false,
							"target": [
								"donald",
								"modi"
							]
						}
					]
				}
			],
			"targets": {
				"App":{
					"viewName": "App",
					"controlId":"idMainApp",
					"id": "idAppView",
					"controlAggregation": "pages",
					"clearAggregation":true,
					"viewLevel":"1"
				},
				"donald": {
					"viewName": "View1",
					"id": "idView1",
					"controlId":"__xmlview1--idAppCon",
					"controlAggregation": "masterPages",
					"clearAggregation":true
				},
				"trumph": {
					"viewName": "Empty",
					"id": "idEmpty",
					"controlId":"__xmlview1--idAppCon",
					"controlAggregation": "detailPages",
					"viewLevel": 1,
					"clearAggregation":true
				},
				"modi": {
					"viewType": "XML",
					"transition": "slide",
					"clearAggregation": true,
					"controlId":"__xmlview1--idAppCon",
					"viewName": "View2",
					"controlAggregation": "detailPages",
					"viewLevel": 2
				}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"resources": {
			"css": [
				{
					"uri": "style/mystyle.css",
					"id": ""
				}
			]
		},
		"models": {
			"local": {
				"type": "sap.ui.model.json.JSONModel",
				"settings": {},
				"preload": true,
				"uri": "model/mockdata/fruitsfile.json"
			},
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {},
				"uri": "i18n/i18n.properties",
				"preload": true,
				"async": true
			}
		}
	}
}