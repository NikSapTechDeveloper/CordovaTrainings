<mvc:View
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="com.nikitatrainings.controller.View1"
    xmlns:html="http://www.w3.org/1999/xhtml"
>
    <Page title="Product List">
        <content>
            <!--<Button text="Go To Next" press="onNext"></Button>-->
            <SearchField
                id="idSearch"
                search="onSearch"
                liveChange="onSearch"
            />
            <List
                items="{ path: 'local>/ProductSet'
			}"
                mode="SingleSelectMaster"
                itemPress="onItemSelect"
                id="idList"
                selectionChange="onSelectChange"
                growing="true"
            >
                <items>
                    <ObjectListItem
                        intro="{local>CATEGORY}"
                        title="{local>NAME}"
                        icon="sap-icon://product"
                        number="{local>PRICE}"
                        numberUnit="{local>CURRENCY_CODE}"
                    >
                        <firstStatus>
                            <ObjectStatus
                                text="{local>TYPE_CODE}"
                                state="Success"
                            />
                        </firstStatus>
                    </ObjectListItem>
                </items>
                <infoToolbar>
                    <OverflowToolbar active="{local>/deviceConnected}">
                        <Label text="{local>/onlineOrOfflineStatusText}" />
                    </OverflowToolbar>
                </infoToolbar>
            </List>
        </content>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    icon="sap-icon://synchronize"
                    press="onSyncPress"
                    tooltip="Load Sync Screen"
                />
                <Button
                    icon="sap-icon://add"
                    press="onAddPress"
                    tooltip="Add new product"
                />
            </Toolbar>
        </footer>
        <headerContent>
            <Button
                icon="sap-icon://action"
                press="onNext"
            />
        </headerContent>
    </Page>
</mvc:View>
