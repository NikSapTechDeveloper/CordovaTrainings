<mvc:View
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="com.nikitatrainings.controller.Empty"
    xmlns:html="http://www.w3.org/1999/xhtml"
>
    <App>
        <pages>
            <Page
                title="Welcome"
                showNavButton="{=${local>/isPhone} === true? true:false}"
                navButtonPress="onNavBack"
            >
                <content>
                    <FlexBox
                        width="100%"
                        height="100%"
                        alignContent="Center"
                        alignItems="Center"
                        justifyContent="Center"
                        fitContainer="true"
                    >
                        <VBox
                            alignContent="Center"
                            alignItems="Center"
                            justifyContent="Center"
                        >
                            <Title
                                text="Welcome to Hybrid Offline first app"
                                width="100%"
                                class="sapUiSmallMarginTop"
                                level="H4"
                                titleStyle="H4"
                            />
                            <Button
                                text="Go to Product Screen"
                                press="onNavBack"
                            />
                        </VBox>
                    </FlexBox>
                </content>
            </Page>
        </pages>
    </App>
</mvc:View>
