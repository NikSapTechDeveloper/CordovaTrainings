<mvc:View
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="com.nikitatrainings.controller.SyncStatus"
    xmlns:html="http://www.w3.org/1999/xhtml"
>
    <Page
        title="The Offline Store Sync Status"
        showNavButton="{=${local>/isPhone} === true? true:false}"
        navButtonPress="onNavBack"
    >
        <content>
            <List
                items="{ path: 'local>/OFFLINE_STORE_NEW'
			}"
                mode="SingleSelectMaster"
                id="idSyncList"
                selectionChange="onSelectChange"
            >
                <items>
                    <ObjectListItem
                        intro="{local>OPERATION}"
                        title="{local>ENTITYSET}"
                        icon="sap-icon://product"
                        numberUnit="{local>SYNCTIME}"
                    >
                        <firstStatus>
                            <ObjectStatus
                                text="{path:'local>SYNCED', formatter:'.formatter.getSyncText'}"
                                state="{path:'local>SYNCED', formatter:'.formatter.getSyncStatus'}"
                            />
                        </firstStatus>
                    </ObjectListItem>
                </items>
                <infoToolbar>
                    <OverflowToolbar active="{local>/deviceConnected}">
                        <Label text="{local>/onlineOrOfflineStatusText}" />
                    </OverflowToolbar>
                </infoToolbar>
            </List>
        </content>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    icon="sap-icon://synchronize"
                    press="onSyncPress"
                    text="Synchronize Offline Data"
                    tooltip="Synchronize changes"
                />
            </Toolbar>
        </footer>
        <!-- <headerContent>
			<Button icon="sap-icon://action" press="onNext"></Button>
		</headerContent> -->
    </Page>
</mvc:View>
