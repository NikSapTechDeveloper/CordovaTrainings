<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    controllerName="com.nikitatrainings.controller.Add"
>
    <Page
        title="Manage Products"
        showNavButton="{=${local>/isPhone} === true? true:false}"
        navButtonPress="onNavBack"
        class="sapUiResponsiveContentPadding"
    >
        <VBox class="sapUiSmallMargin">
            <f:SimpleForm
                id="SimpleFormChange354"
                editable="true"
                layout="ResponsiveGridLayout"
                title="Product Data"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="4"
                emptySpanL="4"
                emptySpanM="4"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false"
            >
                <f:content>
                    <Label text="Product Id" />
                    <Input
                        id="prodId"
                        value="{prod>/prodData/ProductId}"
                        submit="onEnter"
                        editable="false"
                    />
                    <Label text="Name" />
                    <Input value="{prod>/prodData/Name}" />
                    <Label text="Description" />
                    <TextArea value="{prod>/prodData/Description}">
                        <layoutData>
                            <l:GridData span="XL1 L2 M2 S4" />
                        </layoutData>
                    </TextArea>
                    <Label text="Supplier ID" />
                    <Input
                        value="{prod>/prodData/SupplierId}"
                        editable="false"
                    >
                        <layoutData>
                            <l:GridData span="XL1 L2 M2 S4" />
                        </layoutData>
                    </Input>
                    <Label text="Price" />
                    <Input value="{prod>/prodData/Price}" />
                    <Input
                        value="{prod>/prodData/CurrencyCode}"
                        editable="false"
                    >
                        <layoutData>
                            <l:GridData span="XL1 L2 M2 S4" />
                        </layoutData>
                    </Input>
                    <Label text="Category" />
                    <Select
                        id="category"
                        selectedKey="{prod>/prodData/Category}"
                    >
                        <items>
                            <core:Item
                                text="Notebooks"
                                key="Notebooks"
                            />
                            <core:Item
                                text="Projectors"
                                key="Projectors"
                            />
                            <core:Item
                                text="Mice"
                                key="Mice"
                            />
                            <core:Item
                                text="Monitors"
                                key="Monitors"
                            />
                            <core:Item
                                text="Remote"
                                key="Remote"
                            />
                            <core:Item
                                text="Phone"
                                key="Phone"
                            />
                        </items>
                    </Select>
                </f:content>
            </f:SimpleForm>
        </VBox>
        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button
                    id="idSave"
                    text="Save"
                    press="onSave"
                    type="Accept"
                />
                <Button
                    id="idDelete"
                    text="Delete"
                    press="onDelete"
                    type="Reject"
                />
                <Button
                    text="Clear"
                    press="onClear"
                    type="Emphasized"
                />
            </Toolbar>
        </footer>
    </Page>
</mvc:View>
