<mvc:View
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    controllerName="com.nikitatrainings.controller.Login"
    xmlns:html="http://www.w3.org/1999/xhtml"
>
    <App id="idMainApp">
        <Page title="Hybrid Offline-Online Application" class="sapUiResponsiveContentPadding">
            <VBox
                justifyContent="Center"
                alignItems="Center"
                direction="Column"
                width="100%"
                height="100%"
                renderType="Div"
                displayInline="true"
                fitContainer="true"
                visible="true"
            >
                <items>
                    <f:Form
                        width="100%"
                        editable="false"
                        visible="true"
                    >
                        <f:title>
                            <core:Title
                                text="Enter Login Details"
                                level="H1"
                            />
                        </f:title>

                        <f:formContainers>
                            <f:FormContainer>
                                <f:formElements>
                                    <f:FormElement>
                                        <f:label>
                                            <Label text="" />
                                        </f:label>
                                        <f:fields>
                                            <Input
                                                id="idUser"
                                                placeholder="Enter User Id"
                                                type="Text"
                                            />
                                        </f:fields>
                                    </f:FormElement>

                                    <f:FormElement>
                                        <f:label>
                                            <Label text="" />
                                        </f:label>
                                        <f:fields>
                                            <Input
                                                id="idPassword"
                                                placeholder="Enter Password"
                                                type="Password"
                                            />
                                        </f:fields>
                                    </f:FormElement>

                                    <f:FormElement>
                                        <f:label>
                                            <Label text="" />
                                        </f:label>
                                        <f:fields>
                                            <Button
                                                text="Login"
                                                type="Emphasized"
                                                icon="sap-icon://visits"
                                                press="onLogin"
                                            />
                                        </f:fields>
                                    </f:FormElement>

                                    <f:FormElement>
                                        <f:label>
                                            <Label text="" />
                                        </f:label>
                                        <!-- <f:fields>
                                            <Button
                                                text="Login"
                                                press="onGoogleLogin"
                                                icon="../images/GoogleSuite.png"
                                                type="Transparent"
                                            />
                                        </f:fields> -->
                                    </f:FormElement>
                                </f:formElements>
                            </f:FormContainer>
                        </f:formContainers>

                        <f:layout>
                            <f:ResponsiveGridLayout
                                adjustLabelSpan="false"
                                columnsL="2"
                                labelSpanL="3"
                                columnsM="1"
                                labelSpanM="2"
                                labelSpanS="12"
                            />
                        </f:layout>
                    </f:Form>
                </items>
            </VBox>
        </Page>
    </App>
</mvc:View>
