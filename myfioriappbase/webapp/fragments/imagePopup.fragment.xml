<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m">
  <Dialog showHeader="false" verticalScrolling="false">
    <HBox class="sapUiTinyMarginTopBottom sapUiTinyMarginBeginEnd" alignContent="Center"
      alignItems="Center" >
      <Image class="sapUiTinyMarginTopBottom" 
		src="{path:'local>/PhotoData/Picture',formatter:'.formatter.getBase64ToImage'}"
		height="550px" width="550px">
          <customData>
			 <core:CustomData key="IconData" value="{local>/PhotoData}"></core:CustomData>
				 </customData>
	</Image>
    </HBox>
    <endButton>
      <Button text="close" press="onCloseImageDialog"/>
    </endButton>
  </Dialog>
</core:FragmentDefinition>